{
  "name": "web-dev-companion",
  "private": true,
  "license": "MIT",
  "version": "0.1.0-alpha.7",
  "description": "Desktop companion for managing local web development repositories.",
  "author": "Alexander Claes",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20.19.4 <21",
    "pnpm": "10.14.0"
  },
  "scripts": {
    "dev": "vite",
    "test": "vue-tsc --noEmit && vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "build": "vue-tsc && vite build && electron-builder --config.mac.identity=null --config.mac.forceCodeSigning=false --config.mac.notarize=false",
    "release:preflight:mac": "node scripts/verify-macos-release.mjs",
    "release:alpha": "pnpm run release:preflight:mac && vue-tsc && vite build && electron-builder --mac --win --x64",
    "release:alpha:mac": "pnpm run release:preflight:mac && vue-tsc && vite build && electron-builder --mac",
    "release:alpha:win": "vue-tsc && vite build && electron-builder --win --x64",
    "preview": "vite preview"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@types/node": "20.19.39",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.10",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.0.26"
  },
  "main": "dist-electron/main.js"
}
